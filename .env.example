# ============================================================================
# Code-as-Room API Configuration
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The .env file is loaded automatically by run_pipeline.py and
# batch_run_pipeline.py. Values in .env will NOT override environment
# variables already set in your shell — existing env vars always take
# precedence.
#
# You can also use a JSON config file (--config pipeline_config.json)
# or CLI arguments (--model, --base-url, --api-key) instead.
# ============================================================================

# --- Main LLM endpoint (used by text-only stages) ---
# IMPORTANT: If this model does NOT support vision / multimodal inputs
# (e.g. deepseek-reasoner, o1, o3-mini, etc.), you MUST also configure
# the Vision-model section below. Stages 1/2/3/5/12 require image analysis.
SCENEGEN_MODEL=gemini-3.1-pro-preview-thinking
SCENEGEN_BASE_URL=https://your-openai-compatible-endpoint/v1
SCENEGEN_API_KEY=your-api-key

# --- Vision model (used when the main model rejects image content) ---
# Set these when SCENEGEN_MODEL is a text-only reasoning model.
# The pipeline will automatically route image-bearing requests to this
# model while keeping text-only calls on SCENEGEN_MODEL.
#SCENEGEN_VISION_MODEL=gpt-4o
#SCENEGEN_VISION_BASE_URL=https://api.openai.com/v1
#SCENEGEN_VISION_API_KEY=sk-your-vision-api-key

# --- Optional: Stage 11 real texture generation ---
# Supported backends:
#   1. Gemini generateContent API (e.g. gemini-3-pro-image-preview):
#      SCENEGEN_TEXTURE_BASE_URL should be the Gemini API root (e.g.
#      https://generativelanguage.googleapis.com or your proxy).
#   2. DashScope text2image API (e.g. qwen-image-plus, qwen-image-max):
#      SCENEGEN_TEXTURE_BASE_URL should point to a DashScope endpoint.
#      The pipeline auto-detects "dashscope" / "aliyuncs.com" in the URL
#      and routes to DashScope's native /api/v1/services/aigc/text2image/.
#SCENEGEN_TEXTURE_MODEL=gemini-3-pro-image-preview
#SCENEGEN_TEXTURE_BASE_URL=https://your-image-generation-endpoint
#SCENEGEN_TEXTURE_API_KEY=your-texture-api-key

# --- Optional: native OpenAI fallback ---
# OPENAI_API_KEY=sk-your-openai-key
